---
import type { IHeaderProps } from "../types";
const {links} = Astro.props as IHeaderProps;

const currentPath = Astro.url.pathname.replace(/\/+$/, "");
---

<header>
  <nav>


    <ul>
        <li>
          <?xml version="1.0" encoding="utf-8"?><!-- Uploaded to: SVG Repo, www.svgrepo.com, Generator: SVG Repo Mixer Tools -->
          <svg width="34px" height="34px" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0.792725 12.2929L5.08562 8.00002L0.792725 3.70712L2.20694 2.29291L7.91405 8.00002L2.20694 13.7071L0.792725 12.2929Z" fill="#000000"/>
            <path d="M7.00006 15H15.0001V13H7.00006V15Z" fill="#000000"/>
          </svg>
        </li>
      {
        links.map((link) => (
          <li>
            <a href={link.href} target={link.target} class={currentPath === link.href.replace(/\/+$/, "") ? 'active' : ''} >
              {link.name}
            </a>
          </li>
        ))
      }
    </ul>
    <!-- <ul>
        <li><a href="#">Icon</a></li>
        <li><a href="/">Home</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="#">Resources</a></li>
        </ul> -->
  </nav>
</header>

<style>
    header {
      position: sticky;
      top: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      background-color: rgb(240, 218, 54);
      font-family: ui-monospace, "Cascadia Code", Consolas, monospace;
      height: 75px;
      flex-shrink: 0;
    }

    @media (prefers-color-scheme: dark) {
    header {
      background-color: #030712;  /* gray-950 */
    }
  }

    ul {
        display: flex-start;
        align-items: center;
    }

    li {
      display: inline-flex;
      list-style: none;
      margin: 0 16px;
    }

    li > a {
      color: #666;
    }

    li > a.active {
      color: #000;
      font-weight: 500;
    }
</style>
