---
import type { ILink } from "../layouts/Layout.astro";

export interface IProps {
    links: ILink[];
}
const {links} = Astro.props as IProps;
---

<header class="font-mono">
  <nav>
    <ul>
      {
        links.map((link) => (
          <li>
            <a href={link.href} target={link.target}>
              {link.name}
            </a>
          </li>
        ))
      }
    </ul>
    <!-- <ul>
        <li><a href="#">Icon</a></li>
        <li><a href="/">Home</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="#">Resources</a></li>
        </ul> -->
  </nav>
</header>

<style>
    header {
        background-color: rebeccapurple;
    }
    ul {
        display: flex;
    }

    li {
        list-style: none;
        margin: 0 16px;
    }

    li > a {
        color: white;
    }
</style>
