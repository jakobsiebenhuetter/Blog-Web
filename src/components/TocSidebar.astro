---
import type { MarkdownHeading } from "astro";

const { items } = Astro.props as {
  items: MarkdownHeading[];
};
---

<aside class="toc-sidebar">
  <h2>Inhaltsverzeichnis</h2>
  <ul>
    {
      items.map((item) => (
        <li>
          <div>
            <a href={"#" + item.slug}>{item.text}</a>
          </div>
        </li>
      ))
    }
  </ul>
</aside>

<style>
  aside {
    position: sticky;
    top: 0;
  }
   
  a.active {
    color: red;
  }



  @media (max-width: 1000px) {
    .toc-sidebar {
      display: none;
    }
  }
</style>

<script>
    const headings = document.querySelectorAll("h1, h2, h3, h4, h5, h6");
    const tocHeadings = document.querySelectorAll('.toc-sidebar a');
    const main = document.querySelector('.main-scroll') as HTMLElement

    main.addEventListener('scroll', () => {
         headings.forEach((headingElement) => {
            const heading = headingElement as HTMLElement; 
            const headingTop = heading.getBoundingClientRect().top;
            if(headingTop >= 0 && headingTop <= window.innerHeight / 4) {
                heading.style.color = 'red';
            
            tocHeadings.forEach((tocHeading) => {
                if(heading.textContent === tocHeading.textContent) {
                    tocHeading.classList.add('active');
                }
            });

            } else {
                heading.style.color = '';
                tocHeadings.forEach((tocHeading) => {
                    if(heading.textContent === tocHeading.textContent) {
                        tocHeading.classList.remove('active');
                    }
                });
              
            };
         });
    })
</script>