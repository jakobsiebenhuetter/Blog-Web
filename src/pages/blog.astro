---
import Layout from "../layouts/Layout.astro";
import BlogCard from "../components/BlogCard.astro";
// import BlogCard from "../components/svelte/BlogCard/BlogCard.svelte";
// import BlogList from "../components/svelte/BlogList/BlogList.svelte";

import {topics} from "../assets/data/blog/blog.json";
---

<Layout>
  <h1>Blog</h1>
  <ul>
    {topics.length === 0 ? <p style="color: red;">Es sind noch keine Blogeinträge vorhanden.</p> : null}
    {topics.map((topic) => <BlogCard title={topic.title} description={topic.description} href={topic.href} date={topic.date} disabled={topic.disabeld}></BlogCard>)}      
     <!-- <BlogList client:load></BlogList> -->
  </ul>
</Layout>

<style>
  ul {
    list-style: none;
    padding: 6px;
  }
  h1 {
    text-align: center;
    padding: 16px;
  }
</style>
