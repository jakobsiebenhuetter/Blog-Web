---
import Layout from "../layouts/Layout.astro";
import { Content, getHeadings, frontmatter } from "../markdown/web-stack.md";

import {links as headerLinks} from "../assets/data/web-stack/headerLinks.json";
import {links as sidebarLinks} from "../assets/data/web-stack/sidebarLinks.json";

const headings = getHeadings();

---

<Layout
  title={frontmatter.title}
  description={frontmatter.description}
  headerLinks={headerLinks}
  sidebarLinks={sidebarLinks}
  headings={headings}
>
  <article class="prose">
    <Content />
  </article>
</Layout>

<style>
  .prose {
    line-height: 1.6;
  }
</style>