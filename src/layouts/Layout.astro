---
import '../assets/css/global.css';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';

import Footer from '../components/Footer.astro';
import { headerProps, sidebarProps } from '../assets/data/dummyData/dummy';
import type { MarkdownHeading } from 'astro';
import TSLogo from "../images/TS-logo.png";

import TocSidebar from "../components/TocSidebar.astro";
import type { ILink } from '../types';

interface Props {
	title: string;
	description: string;
	headerLinks?: ILink[];
	sidebarLinks?: ILink[];
	headings?: MarkdownHeading[];
}

const {
	title,
	description,
	headerLinks = headerProps.links,
	sidebarLinks = sidebarProps.links,
	headings
} = Astro.props;
---

<!doctype html>
<html lang="de">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/Blog-Web/favicon.svg" />
		<link rel="icon" href="/Blog-Web/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<Header links={headerLinks} />
		<div class="columns">
			<Sidebar links={sidebarLinks} />
			<div class="main-scroll">
				<main class="hero">
					<img src={TSLogo.src} alt="TypeScript Logo" />
					<slot />
					<Footer />
				</main>
				{headings && headings.length ? <TocSidebar items={headings} /> : null}
			</div>
		</div>
	</body>
</html>

<style>
	html,
	body {
		height: 100vh;
		margin: 0;
		padding: 0;
		width: 100%;
		overflow: hidden;
	}

	body {
		display: flex;
		flex-direction: column;
	}

	.columns {
		flex: 1;
		display: flex;
		min-height: 0;
	}

	.main-scroll {
		flex: 1;
		overflow-y: auto;
		display: flex;
		justify-content: center;
		gap: 2rem;
		padding: 2rem 1.5rem;
		width: 100%;
	}

	main {
		flex: 1;
		max-width: 1000px;
		min-width: 0;
	}

	@media (max-width: 767px) {
		html,
		body {
			height: auto;
			overflow: auto;
		}

		.columns {
			flex-direction: column;
		}

		.main-scroll {
			overflow: visible;
			flex-direction: column;
			padding: 1rem;
		}

		main {
			max-width: 100%;
		}
	}

	main > img {
		display: block;
		margin: 0 auto 2rem auto;
		max-width: 150px;
	}
</style>